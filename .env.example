# Configuration Django - Exemple
# Copier ce fichier en .env et remplir avec vos valeurs réelles

# Clé secrète Django - OBLIGATOIRE et à protéger pour la production 
# Générez une clé secrète sécurisée avec : python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here

# Mode debug - Mettre False en production (obligatoire)
DEBUG=False

# Hôtes autorisés - Ajouter votre domaine en production (obligatoire)
# Exemple : ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Configuration Email (optionnel)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Configuration de sécurité pour HTTPS (à activer en production)
# Mettre à True si vous utilisez HTTPS
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# HSTS - HTTP Strict Transport Security (à activer en production)
# Temps en secondes (31536000 = 1 an)
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Configuration de la base de données (optionnel - SQLite par défaut)
# DATABASE_URL=sqlite:///db.sqlite3
# Pour PostgreSQL : DATABASE_URL=postgres://user:password@localhost:5432/dbname
# Pour MySQL : DATABASE_URL=mysql://user:password@localhost:3306/dbname